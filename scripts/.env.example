OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxx
OPENROUTER_MODEL=openai/gpt-5.2
# Exemplos:
# OPENROUTER_MODEL=google/gemini-2.5-pro
# OPENROUTER_MODEL=qwen/qwen-2.5-vl-72b-instruct
# OPENROUTER_MODEL=deepseek/deepseek-chat-v3-0324

OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_SITE_URL=http://localhost
OPENROUTER_APP_NAME=liteparse-ocr-pipeline

# olmOCR container API (OpenAI-compatible)
OLMOCR_API_BASE=http://localhost:8010/v1
OLMOCR_API_KEY=
OLMOCR_MODEL=allenai/olmOCR-2-7B-1025-FP8
OLMOCR_DOCKER_IMAGE=alleninstituteforai/olmocr:latest-with-model
OLMOCR_DOCKER_CONTAINER=olmocr_api
OLMOCR_DOCKER_PORT=8010
OLMOCR_DOCKER_RUN_CMD=vllm serve {model} --host 0.0.0.0 --port {port}
OLMOCR_REQUIRE_GPU=1
