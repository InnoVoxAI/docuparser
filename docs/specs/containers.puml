@startuml
!includeurl https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Container.puml

title Containers

Person(operator, "Operador")
Person(supervisor, "Supervisor")

System_Boundary(system, "Document System") {

    Container(frontend, "Frontend", "React")
    Container(core, "Backend Core", "Django", "Orquestrador")
    Container(ocr, "Backend OCR", "Python", "OCR + classificação básica")
    Container(layout, "Layout Classification Service", "Python/ML/LLM", "Identificação de layout do documento")
    Container(langextract, "LangExtract Service", "Python + LLM", "Extração semântica baseada em schema")
    Container(queue, "Queue", "Redis/RabbitMQ")
    ContainerDb(db, "Database", "PostgreSQL")
}

System_Ext(email, "Email API")
System_Ext(whatsapp, "WhatsApp API")
System_Ext(scanner, "Scanner System")
System_Ext(superlogica, "Superlógica")

Rel(operator, frontend, "usa")
Rel(supervisor, frontend, "configura schemas e layouts")

Rel(email, core, "ingestão")
Rel(whatsapp, core, "ingestão")
Rel(scanner, core, "upload scan")

Rel(core, queue, "jobs")

Rel(queue, ocr, "processamento OCR")
Rel(ocr, layout, "raw_text + tipo documento")
Rel(layout, langextract, "raw_text + layout")
Rel(langextract, core, "json estruturado")

Rel(core, db, "persistência")
Rel(core, superlogica, "integração")

@enduml