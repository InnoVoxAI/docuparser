
@startuml
!includeurl https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Context.puml

title Sistema de Ingestão de Documentos

Person(operator, "Operador")
Person(supervisor, "Supervisor")

System(system, "Sistema de Ingestão de Documentos", "Processa documentos com OCR, classificação de layout e extração semântica")

System_Ext(email, "Email API")
System_Ext(whatsapp, "WhatsApp API")
System_Ext(scanner, "Scanner Corporativo")
System_Ext(superlogica, "Superlógica API")

Rel(email, system, "envia documentos")
Rel(whatsapp, system, "envia documentos")
Rel(scanner, system, "envia documentos digitalizados")

Rel(operator, system, "valida documentos")
Rel(supervisor, system, "configura extração e layouts")
Rel(system, superlogica, "envia dados aprovados")

@enduml