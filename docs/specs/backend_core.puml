@startuml
!includeurl https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Component.puml

title Backend Core (Arquitetura Atualizada)

Container_Boundary(core, "Backend Core") {

    Component(api, "API REST", "Django", "Endpoints para frontend")
    Component(job_manager, "Job Manager", "Gerenciamento de jobs")
    Component(orchestrator, "Orchestrator", "Celery + Event-driven")
    Component(validation, "Validation Service", "Validação humana")
    Component(event_publisher, "Event Publisher", "Publicação de eventos")
    Component(event_consumer, "Event Consumer", "Consumo de eventos")
}

Container(com, "Backend COM")
Container(conect, "Backend CONECT")
Container(ocr, "Backend OCR")
Container(layout, "Layout Service")
Container(langextract, "LangExtract Service")
ContainerDb(db, "PostgreSQL")
Container(queue, "Queue (Redis/RabbitMQ)")

Rel(api, job_manager, "create job")
Rel(job_manager, orchestrator, "dispatch job")
Rel(orchestrator, event_publisher, "publish event")
Rel(event_publisher, queue, "document.received")

Rel(queue, event_consumer, "consume event")
Rel(event_consumer, ocr, "trigger OCR")
Rel(event_consumer, layout, "trigger layout classification")
Rel(event_consumer, langextract, "trigger extraction")
Rel(event_consumer, validation, "pending validation")

Rel(validation, com, "validate document")
Rel(validation, conect, "approve document")

Rel(com, db, "configurações")
Rel(conect, db, "idempotência")
Rel(orchestrator, db, "job status")

@enduml

