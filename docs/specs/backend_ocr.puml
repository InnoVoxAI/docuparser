@startuml
!includeurl https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Component.puml

title Backend OCR

Container_Boundary(ocr, "Backend OCR") {

    Component(classifier, "Classifier")
    Component(ocr_engine, "OCR Engine")
}

Container(queue, "Queue")
Container(langextract, "LangExtract Service")

queue --> classifier
classifier --> ocr_engine
ocr_engine --> langextract

@enduml