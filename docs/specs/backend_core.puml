@startuml
!includeurl https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Component.puml

title Backend Core

Container_Boundary(core, "Backend Core") {
    Component(api, "API REST", "Django")
    Component(ingestion, "Ingestion Service")
    Component(orchestrator, "Orchestrator", "Celery")
    Component(validation, "Validation Service")
    Component(integration, "Superlógica Integration")
}

ContainerDb(db, "PostgreSQL")
Container(queue, "Queue")

api --> ingestion
api --> validation
ingestion --> orchestrator
orchestrator --> queue
validation --> integration
integration --> db
api --> db

@enduml

